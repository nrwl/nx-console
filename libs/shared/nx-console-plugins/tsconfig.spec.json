{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc/jest",
    "module": "commonjs",
    "moduleResolution": "node10",
    "types": [
      "jest",
      "node"
    ],
    "ignoreDeprecations": "6.0",
    "rootDir": "."
  },
  "include": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.d.ts",
    "jest.config.ts"
  ],
  "exclude": [
    "out-tsc"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
